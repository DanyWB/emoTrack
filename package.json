{
  "name": "emotrack",
  "version": "0.1.0",
  "private": true,
  "description": "emoTrack Telegram bot backend MVP",
  "license": "UNLICENSED",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "start:dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "npm run start:dev",
    "start:prod": "node dist/src/main.js",
    "lint": "eslint \"{src,test,prisma}/**/*.ts\"",
    "lint:fix": "eslint \"{src,test,prisma}/**/*.ts\" --fix",
    "format": "prettier --write \"{src,test,prisma}/**/*.ts\"",
    "test": "jest --passWithNoTests",
    "test:unit": "jest --runInBand test/unit",
    "test:integration": "jest --runInBand test/integration",
    "test:db": "jest --runInBand --config jest.db.config.js",
    "test:coverage": "jest --runInBand --coverage",
    "test:watch": "jest --watch",
    "check": "npm run lint && npm run build && npm run test:coverage",
    "audit:prod": "npm audit --omit=dev",
    "verify": "npm run check && npm run test:db && npm run audit:prod",
    "prisma:migrate": "prisma migrate dev",
    "prisma:generate": "prisma generate",
    "prisma:seed": "prisma db seed"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.1.8",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.8",
    "@nestjs/platform-express": "^11.1.8",
    "@nestjs/terminus": "^11.0.0",
    "@prisma/client": "^6.16.3",
    "bullmq": "^5.63.0",
    "chartjs-node-canvas": "^5.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "dayjs": "^1.11.19",
    "ioredis": "^5.8.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "telegraf": "^4.16.3"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.8",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.5.2",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.44.1",
    "@typescript-eslint/parser": "^8.44.1",
    "eslint": "^9.36.0",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^30.1.3",
    "prettier": "^3.6.2",
    "prisma": "^6.16.3",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.4",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.2"
  }
}
